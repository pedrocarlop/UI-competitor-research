{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/credential-registry.schema.json",
  "title": "CompetitorCredentialRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": ["competitors"],
  "properties": {
    "competitors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["competitor_name"],
        "oneOf": [
          {
            "required": ["email", "password"],
            "not": {
              "anyOf": [
                { "required": ["email_env"] },
                { "required": ["password_env"] }
              ]
            }
          },
          {
            "required": ["email_env", "password_env"],
            "not": {
              "anyOf": [
                { "required": ["email"] },
                { "required": ["password"] }
              ]
            }
          }
        ],
        "properties": {
          "competitor_name": {
            "type": "string",
            "minLength": 1
          },
          "login_url": {
            "type": "string",
            "format": "uri"
          },
          "email": {
            "type": "string",
            "minLength": 3
          },
          "password": {
            "type": "string",
            "minLength": 1
          },
          "email_env": {
            "type": "string",
            "minLength": 1
          },
          "password_env": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          },
          "start_url": {
            "type": "string",
            "format": "uri"
          },
          "navigation_hints": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
