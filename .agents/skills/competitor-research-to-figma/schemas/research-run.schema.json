{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/research-run.schema.json",
  "title": "CompetitorResearchRun",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "run_id",
    "run_directory",
    "started_at",
    "updated_at",
    "input",
    "setup_validation",
    "discovered_competitors",
    "included_competitors",
    "excluded_competitors",
    "captures",
    "cross_competitor_findings",
    "warnings",
    "manual_intervention_checkpoints"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "run_directory": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_description"],
      "properties": {
        "feature_description": {
          "type": "string"
        },
        "research_name": {
          "type": "string"
        },
        "figma_destination_url": {
          "type": "string",
          "format": "uri"
        },
        "company_name": {
          "type": "string"
        },
        "credential_registry_path": {
          "type": "string"
        },
        "catalog_path": {
          "type": "string"
        },
        "resume_from_run_path": {
          "type": "string"
        },
        "competitor_allowlist": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "locale": {
          "type": "string"
        },
        "evidence_import_path": {
          "type": "string"
        }
      }
    },
    "setup_validation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "figma", "browser"],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "figma": {
          "$ref": "#/$defs/toolCheck"
        },
        "browser": {
          "$ref": "#/$defs/toolCheck"
        }
      }
    },
    "discovered_competitors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/discoveredCompetitor"
      }
    },
    "included_competitors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "excluded_competitors": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/excludedCompetitor"
      }
    },
    "captures": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/capture"
      }
    },
    "cross_competitor_findings": {
      "$ref": "#/$defs/crossCompetitorFindings"
    },
    "figma_export": {
      "$ref": "#/$defs/figmaExport"
    },
    "market_context": {
      "$ref": "#/$defs/marketContext"
    },
    "citations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/inlineCitation"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "manual_intervention_checkpoints": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/manualCheckpoint"
      }
    }
  },
  "$defs": {
    "toolCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "verification_level", "summary", "signals", "instructions"],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "verification_level": {
          "type": "string",
          "enum": ["missing", "detected", "verified"]
        },
        "summary": {
          "type": "string"
        },
        "signals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "instructions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verified_with": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "discoveredCompetitor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "competitor_name",
        "product_url",
        "login_url",
        "reason_for_inclusion",
        "confidence",
        "product_category"
      ],
      "properties": {
        "competitor_name": {
          "type": "string"
        },
        "product_url": {
          "type": "string",
          "format": "uri"
        },
        "login_url": {
          "type": "string",
          "format": "uri"
        },
        "start_url": {
          "type": "string",
          "format": "uri"
        },
        "reason_for_inclusion": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": ["high", "medium", "low"]
        },
        "product_category": {
          "type": "string"
        },
        "keyword_matches": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "excludedCompetitor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["competitor_name", "reason"],
      "properties": {
        "competitor_name": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "capture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "competitor_name",
        "status",
        "steps",
        "summary",
        "analysis",
        "warnings"
      ],
      "properties": {
        "competitor_name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["captured", "partial", "excluded", "blocked"]
        },
        "summary": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/step"
          }
        },
        "analysis": {
          "$ref": "#/$defs/analysis"
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "navigation_hints_used": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "resume_url": {
          "type": "string"
        },
        "sentiment": {
          "$ref": "#/$defs/competitorSentiment"
        },
        "pricing": {
          "$ref": "#/$defs/competitorPricing"
        },
        "case_studies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/caseStudy"
          }
        },
        "developer_discourse": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/developerDiscourseEntry"
          }
        }
      }
    },
    "step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_number",
        "step_label",
        "screenshot_path",
        "url",
        "change_note",
        "why_it_matters"
      ],
      "properties": {
        "step_number": {
          "type": "integer",
          "minimum": 1
        },
        "step_label": {
          "type": "string"
        },
        "screenshot_path": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "change_note": {
          "type": "string"
        },
        "why_it_matters": {
          "type": "string"
        },
        "visible_headings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visible_text_snippets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "experience_summary",
        "step_reconstruction",
        "visible_ui_elements",
        "inferred_capabilities",
        "interaction_patterns",
        "strengths",
        "friction_points",
        "reusable_ideas",
        "caveats"
      ],
      "properties": {
        "experience_summary": {
          "type": "string"
        },
        "step_reconstruction": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "visible_ui_elements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "inferred_capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "interaction_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strengths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "friction_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reusable_ideas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "caveats": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "design_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "information_architecture": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unique_differentiators": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "crossCompetitorFindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recurring_capabilities",
        "recurring_patterns",
        "recurring_strengths",
        "recurring_friction_points",
        "coverage_summary"
      ],
      "properties": {
        "recurring_capabilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recurring_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recurring_strengths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "recurring_friction_points": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "coverage_summary": {
          "type": "string"
        },
        "feature_matrix": {
          "$ref": "#/$defs/featureMatrix"
        },
        "sentiment_themes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "strategic_thesis": {
          "type": "string"
        },
        "strategic_narrative": {
          "type": "string"
        },
        "thematic_deep_dives": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/thematicDeepDive"
          }
        }
      }
    },
    "figmaExport": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "destination_url",
        "page_name",
        "status",
        "layout_plan_path"
      ],
      "properties": {
        "destination_url": {
          "type": "string",
          "format": "uri"
        },
        "page_name": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["planned", "exported", "skipped"]
        },
        "layout_plan_path": {
          "type": "string"
        },
        "asset_manifest_path": {
          "type": "string"
        },
        "write_payload_path": {
          "type": "string"
        },
        "html_board_path": {
          "type": "string"
        },
        "capture_payload_path": {
          "type": "string"
        },
        "exported_at": {
          "type": "string",
          "format": "date-time"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "manualCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["competitor_name", "reason", "url", "created_at"],
      "properties": {
        "competitor_name": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "competitorSentiment": {
      "type": "object",
      "required": ["competitor_name", "overall_direction", "top_praised", "top_criticized", "notable_quotes", "entries"],
      "properties": {
        "competitor_name": { "type": "string" },
        "overall_direction": { "type": "string", "enum": ["positive", "negative", "mixed", "neutral"] },
        "rating": {
          "type": "object",
          "properties": {
            "score": { "type": "number" },
            "max": { "type": "number" },
            "source": { "type": "string" }
          }
        },
        "review_count": { "type": "integer" },
        "top_praised": { "type": "array", "items": { "type": "string" } },
        "top_criticized": { "type": "array", "items": { "type": "string" } },
        "notable_quotes": { "type": "array", "items": { "type": "string" } },
        "entries": { "type": "array", "items": { "$ref": "#/$defs/sentimentEntry" } }
      }
    },
    "sentimentEntry": {
      "type": "object",
      "required": ["source_url", "source_type", "source_name", "sentiment", "quote_or_paraphrase", "theme"],
      "properties": {
        "source_url": { "type": "string" },
        "source_type": { "type": "string", "enum": ["app_store", "review_platform", "reddit", "forum", "social", "developer_community", "case_study", "news", "other"] },
        "source_name": { "type": "string" },
        "date": { "type": "string" },
        "sentiment": { "type": "string", "enum": ["positive", "negative", "mixed", "neutral"] },
        "quote_or_paraphrase": { "type": "string" },
        "theme": { "type": "string" }
      }
    },
    "competitorPricing": {
      "type": "object",
      "required": ["competitor_name", "pricing_model", "tiers", "enterprise_available", "notes", "confidence"],
      "properties": {
        "competitor_name": { "type": "string" },
        "pricing_model": { "type": "string" },
        "currency": { "type": "string" },
        "tiers": { "type": "array", "items": { "$ref": "#/$defs/pricingTier" } },
        "free_tier": { "$ref": "#/$defs/pricingTier" },
        "enterprise_available": { "type": "boolean" },
        "pricing_page_url": { "type": "string" },
        "screenshot_path": { "type": "string" },
        "notes": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
        "cost_breakdowns": { "type": "array", "items": { "$ref": "#/$defs/costBreakdown" } },
        "operational_fees": { "type": "array", "items": { "type": "string" } },
        "notable_strategies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "pricingTier": {
      "type": "object",
      "required": ["tier_name", "key_features"],
      "properties": {
        "tier_name": { "type": "string" },
        "price": { "type": "string" },
        "billing_frequency": { "type": "string" },
        "key_features": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "featureMatrix": {
      "type": "object",
      "required": ["feature_name", "subfeatures", "table_stakes", "differentiators"],
      "properties": {
        "feature_name": { "type": "string" },
        "subfeatures": { "type": "array", "items": { "$ref": "#/$defs/subfeatureEntry" } },
        "table_stakes": { "type": "array", "items": { "type": "string" } },
        "differentiators": { "type": "array", "items": { "type": "string" } }
      }
    },
    "subfeatureEntry": {
      "type": "object",
      "required": ["subfeature_name", "description", "support_by_competitor"],
      "properties": {
        "subfeature_name": { "type": "string" },
        "description": { "type": "string" },
        "support_by_competitor": { "type": "object", "additionalProperties": { "type": "string", "enum": ["supported", "partial", "not_supported", "unknown"] } },
        "detail_by_competitor": { "type": "object", "additionalProperties": { "type": "string" } },
        "citation_by_competitor": { "type": "object", "additionalProperties": { "type": "integer" } },
        "constraints_by_competitor": { "type": "object", "additionalProperties": { "type": "string" } },
        "best_implementation": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "marketContext": {
      "type": "object",
      "required": ["domain", "market_segments", "key_trends", "recent_events", "sources"],
      "properties": {
        "domain": { "type": "string" },
        "market_segments": { "type": "array", "items": { "type": "string" } },
        "key_trends": { "type": "array", "items": { "type": "string" } },
        "recent_events": { "type": "array", "items": { "type": "string" } },
        "regulatory_notes": { "type": "array", "items": { "type": "string" } },
        "sources": { "type": "array", "items": { "type": "object", "properties": { "title": { "type": "string" }, "url": { "type": "string" } } } },
        "regional_analyses": { "type": "array", "items": { "$ref": "#/$defs/regionalAnalysis" } }
      }
    },
    "inlineCitation": {
      "type": "object",
      "required": ["ref_number", "title", "url"],
      "properties": {
        "ref_number": { "type": "integer" },
        "title": { "type": "string" },
        "url": { "type": "string" },
        "accessed_date": { "type": "string" }
      }
    },
    "thematicDeepDive": {
      "type": "object",
      "required": ["theme_title", "narrative", "competitors_compared", "key_insight", "evidence_urls"],
      "properties": {
        "theme_title": { "type": "string" },
        "narrative": { "type": "string" },
        "competitors_compared": { "type": "array", "items": { "type": "string" } },
        "key_insight": { "type": "string" },
        "evidence_urls": { "type": "array", "items": { "type": "string" } }
      }
    },
    "caseStudy": {
      "type": "object",
      "required": ["company_name", "use_case", "competitor_used", "source_url", "source_type", "confidence"],
      "properties": {
        "company_name": { "type": "string" },
        "use_case": { "type": "string" },
        "competitor_used": { "type": "string" },
        "outcome": { "type": "string" },
        "source_url": { "type": "string" },
        "source_type": { "type": "string", "enum": ["case_study_page", "blog_post", "press_release", "community_post", "news_article"] },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "developerDiscourseEntry": {
      "type": "object",
      "required": ["source_url", "source_name", "topic", "sentiment", "key_point"],
      "properties": {
        "source_url": { "type": "string" },
        "source_name": { "type": "string" },
        "topic": { "type": "string" },
        "sentiment": { "type": "string", "enum": ["positive", "negative", "mixed", "neutral"] },
        "key_point": { "type": "string" },
        "date": { "type": "string" }
      }
    },
    "costBreakdown": {
      "type": "object",
      "required": ["cost_dimension", "rate"],
      "properties": {
        "cost_dimension": { "type": "string" },
        "rate": { "type": "string" },
        "conditions": { "type": "string" }
      }
    },
    "regulatoryContext": {
      "type": "object",
      "required": ["jurisdiction", "regulation_name", "impact_summary", "affected_competitors", "evidence_url", "confidence"],
      "properties": {
        "jurisdiction": { "type": "string" },
        "regulation_name": { "type": "string" },
        "effective_date": { "type": "string" },
        "impact_summary": { "type": "string" },
        "affected_competitors": { "type": "array", "items": { "type": "string" } },
        "evidence_url": { "type": "string" },
        "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
      }
    },
    "regionalAnalysis": {
      "type": "object",
      "required": ["locale", "market_overview", "dominant_payment_methods", "regulatory_contexts", "competitor_coverage", "evidence_urls"],
      "properties": {
        "locale": { "type": "string" },
        "market_overview": { "type": "string" },
        "dominant_local_platforms": { "type": "array", "items": { "type": "string" } },
        "regulatory_contexts": { "type": "array", "items": { "$ref": "#/$defs/regulatoryContext" } },
        "locale_specific_pricing": { "type": "string" },
        "competitor_coverage": { "type": "object", "additionalProperties": { "type": "string" } },
        "evidence_urls": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
