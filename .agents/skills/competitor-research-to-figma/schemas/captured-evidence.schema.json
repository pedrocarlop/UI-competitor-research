{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/captured-evidence.schema.json",
  "title": "CapturedEvidenceImport",
  "type": "object",
  "additionalProperties": false,
  "required": ["competitors"],
  "properties": {
    "competitors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["competitor_name", "status", "steps", "warnings"],
        "properties": {
          "competitor_name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": ["captured", "partial", "blocked", "excluded"]
          },
          "summary": {
            "type": "string"
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "step_label",
                "screenshot_path",
                "url",
                "change_note",
                "why_it_matters"
              ],
              "properties": {
                "step_label": {
                  "type": "string",
                  "minLength": 1
                },
                "screenshot_path": {
                  "type": "string",
                  "minLength": 1
                },
                "url": {
                  "type": "string",
                  "format": "uri"
                },
                "change_note": {
                  "type": "string",
                  "minLength": 1
                },
                "why_it_matters": {
                  "type": "string",
                  "minLength": 1
                },
                "visible_headings": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "visible_text_snippets": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
