# No environment variables are required for public research mode.
# The skill works out of the box with just a research question.

# Optional: Browser automation (for automated screenshot capture)
BROWSER_AGENT_COMMAND=
PLAYWRIGHT_WS_ENDPOINT=
HEADLESS=true

# Optional: Figma export (only needed when exporting research to a Figma board)
FIGMA_ACCESS_TOKEN=
FIGMA_API_TOKEN=
FIGMA_WRITE_COMMAND=
