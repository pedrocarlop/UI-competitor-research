{
  "name": "competitor-research",
  "version": "2.0.0",
  "description": "Skill for deep competitor research using public evidence — websites, help centers, changelogs, app stores, reviews — producing markdown dossiers with screenshots and sourced findings.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check:setup": "tsx .agents/skills/competitor-research-to-figma/scripts/checkSetup.ts",
    "discover": "tsx .agents/skills/competitor-research-to-figma/scripts/discoverCompetitors.ts",
    "capture": "tsx .agents/skills/competitor-research-to-figma/scripts/captureCompetitorFlows.ts",
    "ingest:evidence": "tsx .agents/skills/competitor-research-to-figma/scripts/ingestCapturedEvidence.ts",
    "analyze": "tsx .agents/skills/competitor-research-to-figma/scripts/analyzeCapturedFlows.ts",
    "export:figma": "tsx .agents/skills/competitor-research-to-figma/scripts/exportResearchToFigma.ts",
    "generate:report": "tsx .agents/skills/competitor-research-to-figma/scripts/generateReport.ts",
    "run:research": "tsx .agents/skills/competitor-research-to-figma/scripts/runResearch.ts"
  },
  "dependencies": {
    "playwright": "^1.54.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
